#######################################
# WM-INDEPENDENT HOTKEYS
#######################################

# App launcher group
super + {t,f,o,c,e,i}
    { \
      $HOME/.local/kitty.app/bin/kitty, \
      firefox, \
      $HOME/Applications/Obsidian-1.6.7.AppImage &>/dev/null & disown, \
      zed, \
      thunar, \
      ~/Applications/tidal-hifi-7.0.1.AppImage --no-sandbox &>/dev/null & disown \
    }

# Reload sxhkd
super + Escape
    pkill -USR1 -x sxhkd

# Rofi launcher
super + space
    $HOME/.config/rofi/launchers/type-2/launcher.sh
#######################################
# BSPWM HOTKEYS
#######################################

# Power options
super + shift + Delete
    $HOME/.config/rofi/powermenu/type-1/powermenu.sh

# Close / kill window
super + q
    bspc node -{c,k}

# Minimise current window
super + m
    bspc node --flag hidden=on

# Minimise all except current
super + alt + m
    bspc query -N -d -n .window.!focused | xargs -I winid bspc node winid --flag hidden=on

# Restore latest hidden window
super + u
    last=$(bspc query -N -n .window.hidden 2>/dev/null | tail -n 1); \
    [ -n "$last" ] && bspc node "$last" --flag hidden=off

# Restore all hidden windows
super + shift + u
    bspc query -N -d -n .window.hidden | xargs -I winid bspc node winid --flag hidden=off

# Send newest marked node to newest preselect
super + y
    bspc node newest.marked.local -n newest.!automatic.local

# Swap with biggest window
super + g
    bspc node -s biggest.window

# Flip vertically/horizontally
super + {v,h}
    bspc node @/ -f {horizontal,vertical}

# Balance all windows
super + backslash
    bspc node @/ -e balance

# Rotate tree
super + shift + {Left,Right}
    bspc node @/ -C {forward,backward}

# Swap with directional window
super + shift + {h,j,k,l}
    bspc node -s {west,south,north,east}

# Equalize window sizes
super + equal
    bspc node @/ -e equalize

#######################################
# WINDOW STATES / FLAGS
#######################################

# Toggle fullscreen
super + alt + g
    if bspc query -N -n focused.fullscreen &>/dev/null; \
    then bspc node -t tiled; \
    else bspc node -t fullscreen; \
    fi

# Window states
super + {s,shift + s,w}
    bspc node -t {tiled,pseudo_tiled,floating}

# Node flags
super + ctrl + {m,x,y,z}
    bspc node -g {marked,locked,sticky,private}

#######################################
# FOCUS / NAVIGATION
#######################################

# Directional focus
super + {Left,Down,Up,Right}
    bspc node -f {west,south,north,east}

# Focus path jumps
super + {p,b,comma,period}
    bspc node -f @{parent,brother,first,second}

# Focus next/previous window
super + {_,shift + }c
    bspc node -f {next,prev}.local.!hidden.window

# Focus next/prev desktop
super + bracket{left,right}
    bspc desktop -f {prev,next}.local

# Focus last node/desktop
super + {grave,Tab}
    bspc {node,desktop} -f last

# Focus older/newer window (remove duplicate directional binds!)
super + alt + Left
    bspc node -f older

super + alt + Right
    bspc node -f newer

#######################################
# MOVE BETWEEN DESKTOPS
#######################################

# Focus or send to desktop
super + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} '^{1-9,10}'

# Move to next/prev desktop
super + {_,shift + }Tab
    bspc desktop -f {next,prev}.local

# Send to next/prev desktop
super + alt + {_,shift + }Tab
    bspc node -d {next,prev}.local



#######################################
# PRESELECT
#######################################

super + ctrl + {h,j,k,l}
    bspc node -p {west,south,north,east}

super + ctrl + {1-9}
    bspc node -o 0.{1-9}

super + ctrl + shift + space
    bspc query -N -d | xargs -I id bspc node id -p cancel

#######################################
# MOVE / RESIZE
#######################################

# Expand
super + alt + {h,j,k,l}
    bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# Contract
super + alt + shift + {h,j,k,l}
    bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# Move floating window
super + alt + {Left,Down,Up,Right}
    bspc node -v {-20 0,0 20,0 -20,20 0}

#######################################
# AUDIO
#######################################

XF86AudioRaiseVolume
    wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+

XF86AudioLowerVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-

XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Media controls
XF86AudioPlay
    playerctl play-pause && notify-send -u low -t 1500 "⏯ $(playerctl metadata title)"

XF86AudioPause
    playerctl pause && notify-send -u low -t 1500 "⏸ $(playerctl metadata title)"

XF86AudioNext
    playerctl next; notify-send -u low -t 1500 "Now Playing" "$(playerctl metadata artist) - $(playerctl metadata title)"

XF86AudioPrev
    playerctl previous; notify-send -u low -t 1500 "Now Playing" "$(playerctl metadata artist) - $(playerctl metadata title)"

super + ctrl + Right
    playerctl next; notify-send -u low -t 1500 "Now Playing" "$(playerctl metadata artist) - $(playerctl metadata title)"

super + ctrl + Left
    playerctl previous; notify-send -u low -t 1500 "Now Playing" "$(playerctl metadata artist) - $(playerctl metadata title)"

super + ctrl + space
    playerctl play-pause && notify-send -u low -t 1500 "⏯ $(playerctl metadata title)"

######################################
# BRIGHTNESS
#######################################

XF86MonBrightnessUp
    brightnessctl -e set +2%

XF86MonBrightnessDown
    brightnessctl --exponent=6 -n set 2%-

#######################################
# SCREENSHOTS
#######################################

# Full screen → clipboard
super + Print
    maim | xclip -selection clipboard -t image/png && \
    notify-send "Screenshot Captured!" "Full screen copied"

# Selection → clipboard
super + shift + Print
    maim -s | xclip -selection clipboard -t image/png && \
    notify-send "Screenshot Captured!" "Selection copied"
