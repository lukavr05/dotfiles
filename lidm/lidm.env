# Environment variables for lidm
# Add your custom environment variables here in KEY=VALUE format

# Set default session to bspwm
LIDM_DEFAULT_SESSION=bspwm

# Theme configuration
THEME=kanagawa-dragon

# XDG variables for bspwm
XDG_SESSION_TYPE=x11
XDG_CURRENT_DESKTOP=bspwm
XDG_DEFAULT_SESSION=bspwm
XDG_SEAT=seat0
XDG_VTNR=1

# Cursor theme (prevents cursor flicker on login)
XCURSOR_THEME=Adwaita
XCURSOR_SIZE=24

# BSPWM_SOCKET=/tmp/bspwm-socket