#! /bin/sh

# Start sxhkd if not running
pgrep -x sxhkd > /dev/null || sxhkd &

# Workspaces
bspc monitor -d I II III

# Basic settings
bspc config border_width         2
bspc config window_gap           6
bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      true

# Visual feedback settings
bspc config pointer_follows_monitor true
bspc config pointer_motion_interval 8

# Appearance
bspc config normal_border_color  "#444444"
bspc config focused_border_color "#8ec07c"
bspc config presel_feedback_color "#8ec07c"

# Window management rules
bspc rule -a Gimp desktop='^II' state=floating follow=on
bspc rule -a Firefox desktop='^I'
bspc rule -a Chromium desktop='^I'
bspc rule -a mplayer2 state=floating
bspc rule -a Kupfer.py focus=on
bspc rule -a Screenkey manage=off
bspc rule -a '*:Dialog' state=floating
bspc rule -a '*:floating' state=floating
bspc rule -a '*:notification' state=floating
bspc rule -a '*:scratchpad' state=floating sticky=on

# Cursor theme
export XCURSOR_THEME="WinSur Dark Cursors"
export XCURSOR_SIZE=24
xsetroot -cursor_name left_ptr

# Autostart applications with error handling
{
    nm-applet &
    pulseaudio --start &
    picom --experimental-backends --config ~/.config/picom/picom.conf &
    nitrogen --restore &
    dunst &
    polybar &
} &

# Map Caps Lock to Escape
setxkbmap -option caps:escape

# set default volume to 50%
pactl set-sink-volume @DEFAULT_SINK@ 50%



